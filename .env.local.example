# Talkative Yoel · Groq
# Get a free key at https://console.groq.com/keys
# Copy this file to .env.local and paste your real key there (NOT here).
GROQ_API_KEY=gsk_REPLACE_ME

# Model: default is llama-3.3-70b-versatile (free tier, high quality).
# Other good options:
#   llama-3.1-8b-instant       (faster, lower quality)
#   meta-llama/llama-4-scout-17b-16e-instruct
#   moonshotai/kimi-k2-instruct
GROQ_MODEL=llama-3.3-70b-versatile

# Legacy · used by /api/chat (Gemini page-aware chat). Optional.
GOOGLE_API_KEY=your_gemini_key_here
