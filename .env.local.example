# Talkative Yoel · OpenRouter
# Get a free key at https://openrouter.ai/keys
# Replace the placeholder below with your actual key in .env.local (NOT here).
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Model: "openrouter/free" routes through any free-tier model OpenRouter has available.
# You can override to a specific free model like:
#   meta-llama/llama-3.1-8b-instruct:free
#   google/gemini-2.0-flash-exp:free
#   nvidia/nemotron-nano-9b-v2:free
OPENROUTER_MODEL=openrouter/free

# Optional: shown in OpenRouter logs / referral
OPENROUTER_SITE_URL=https://yoel.pw
OPENROUTER_SITE_NAME=yoel.pw

# Legacy · used by /api/chat (Gemini page-aware chat). Optional.
GOOGLE_API_KEY=your_gemini_key_here
